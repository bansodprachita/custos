DATABASE_URL="file:./dev.db"
PORT=4000

# Used to sign login sessions. Generate a real random value for anything
# beyond local dev, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev-secret-change-me"

# Exact origin of the deployed frontend, e.g. https://custos.vercel.app
# Leave unset for local dev — CORS then allows any origin.
FRONTEND_URL=
