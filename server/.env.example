DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
PORT=4000

# Used to sign login sessions. Generate a real random value for anything
# beyond local dev, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev-secret-change-me"

# Exact origin of the deployed frontend, e.g. https://custos.vercel.app
# Leave unset for local dev — CORS then allows any origin.
FRONTEND_URL=

# Full service-account JSON as a single-line string, from Firebase Console >
# Project settings > Service accounts > Generate new private key. Only
# needed if you want Google sign-in working — everything else runs without it.
FIREBASE_SERVICE_ACCOUNT=
