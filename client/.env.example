# Leave unset for local development (falls back to http://localhost:4000).
# Set this to your deployed backend URL when building for production, e.g.:
# VITE_API_URL=https://custos-api.onrender.com
VITE_API_URL=

# Firebase project config, from Firebase Console > Project settings > Your apps.
# These are public identifiers, safe to expose in frontend code — Firebase's
# actual security boundary is the service account key on the backend.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
